# =============================================================================
# Pulse Coffee — Backend Environment Variables
# Copy to .env and fill values. Never commit .env. Production reads from
# AWS Parameter Store (SecureString), not from a .env file.
# =============================================================================

# --- Runtime ---------------------------------------------------------------
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- Process role gates (default: both enabled, suitable for local dev) ---
# Set API_ENABLED=false on dedicated worker tasks (no HTTP listener).
# Set WORKERS_ENABLED=false on API replicas so they don't all poll the outbox.
# Typical ECS deployment:
#   API task    → API_ENABLED=true  WORKERS_ENABLED=false
#   Worker task → API_ENABLED=false WORKERS_ENABLED=true
API_ENABLED=true
WORKERS_ENABLED=true

# --- PostgreSQL ------------------------------------------------------------
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_USER=pulse
DATABASE_PASSWORD=pulse
DATABASE_NAME=pulse
DATABASE_SSL=false
DATABASE_LOGGING=false

# --- Redis -----------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# --- JWT (Phase 1: local JWT + bcrypt. Phase 2: AWS Cognito) ---------------
JWT_ACCESS_SECRET=replace-me-with-32+-random-bytes-base64
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=replace-me-with-different-32+-random-bytes
JWT_REFRESH_TTL=30d
BCRYPT_ROUNDS=12

# --- Stripe ----------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_API_VERSION=2024-06-20

# --- Clover POS ------------------------------------------------------------
CLOVER_API_BASE_URL=https://api.clover.com
CLOVER_MERCHANT_ID=
CLOVER_API_KEY=

# --- Telegram (owner alerts) ----------------------------------------------
# When BOTH TELEGRAM_BOT_TOKEN and TELEGRAM_OWNER_CHAT_ID are set, the
# TelegramService dispatches real Bot API sends in addition to the
# [telegram] {...} log line. When either is empty, the service falls back
# to stub-only mode: it still logs [telegram] {...} but performs no fetch.
# This is the intentional graceful-degradation pattern for local dev and
# pre-credential states — see decision-log entry "Real Telegram Bot API +
# APNs delivery (C8)".
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=

# --- Apple Push Notification Service --------------------------------------
# All four required APNS_* values (KEY_ID, TEAM_ID, BUNDLE_ID,
# PRIVATE_KEY_PATH) must be set for real APNs delivery. If any one is
# empty — or if the .p8 file at PRIVATE_KEY_PATH is missing/unreadable —
# PushNotificationService runs in stub-only mode: it logs [push] {...}
# on every send() call without constructing the apn Provider.
#
# APNS_PRIVATE_KEY_PATH points at a `.p8` file from Apple Developer; the
# file itself MUST NOT be committed (the `*.p8` glob and
# `apps/api/secrets/` directory are in .gitignore). Convention is to
# place it at `apps/api/secrets/AuthKey_<KeyID>.p8`.
#
# APNS_USE_SANDBOX=true selects the sandbox APNs endpoint (development
# devices). Set to false for production-built apps.
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.pulsecoffee.app
APNS_PRIVATE_KEY_PATH=
APNS_USE_SANDBOX=true

# --- Sentry ---------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# --- PostHog --------------------------------------------------------------
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# --- AWS (used in Phase 2 / production) ----------------------------------
AWS_REGION=us-east-1
AWS_PARAMETER_STORE_PREFIX=/pulse/
SQS_OUTBOX_QUEUE_URL=
SQS_DLQ_URL=
S3_MENU_IMAGES_BUCKET=

# --- Throttling overrides (optional) -------------------------------------
THROTTLE_AUTH_LOGIN_PER_MIN=5
THROTTLE_AUTH_REGISTER_PER_MIN=10
THROTTLE_CHECKOUT_PER_MIN=3
THROTTLE_MENU_PER_MIN=60
THROTTLE_ADMIN_PER_MIN=30
