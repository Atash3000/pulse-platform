# ----- Node / NestJS -----------------------------------------------------
node_modules/
dist/
build/
coverage/
.tsbuildinfo
*.tsbuildinfo

# ----- Environment / secrets --------------------------------------------
# Real values (JWT secrets, Stripe keys, Clover keys, Telegram tokens)
# never get committed. .env.example IS committed as the template.
.env
.env.*
!.env.example

# APNs auth keys (.p8 / .pem files) and other private keys
*.pem
*.p8
*.key

# APNs secrets directory — conventional location for the .p8 file
# (APNS_PRIVATE_KEY_PATH=apps/api/secrets/AuthKey_<KeyID>.p8). Belt-and-
# suspenders with the *.p8 glob above: catches the directory even if a
# future file is renamed without the extension.
apps/api/secrets/

# AWS / cloud credentials accidentally dropped in the tree
.aws/
credentials.json

# ----- Logs --------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ----- Editors / OS -----------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ----- Local docker volumes / generated data ----------------------------
.docker/
*.sqlite
*.sqlite3

# ----- Coverage / test output -------------------------------------------
.nyc_output/
junit.xml
test-results/

# ----- Claude session metadata (if any) ---------------------------------
.claude/

# ----- iOS / Xcode ------------------------------------------------------
# The .xcodeproj is generated by XcodeGen from apps/ios/project.yml.
# Treat it as a build artifact: never committed. Run `make project`
# (from apps/ios/) after pulling to regenerate. See decision-log entry
# "[iOS] XcodeGen for project file management".
#
# EXCEPTION — `Package.resolved`:
# Xcode stores the SPM dependency lockfile inside the .xcodeproj at:
#   project.xcworkspace/xcshareddata/swiftpm/Package.resolved
# We commit it for reproducible builds. The negation pattern below
# allow-lists ONLY that file (and the directory chain leading to it),
# leaving everything else under .xcodeproj/ ignored. See decision-log
# entry "[iOS] Sentry + PostHog + AppConfig wiring" for why.
apps/ios/PulseCoffeeApp.xcodeproj/*
!apps/ios/PulseCoffeeApp.xcodeproj/project.xcworkspace/
apps/ios/PulseCoffeeApp.xcodeproj/project.xcworkspace/*
!apps/ios/PulseCoffeeApp.xcodeproj/project.xcworkspace/xcshareddata/
apps/ios/PulseCoffeeApp.xcodeproj/project.xcworkspace/xcshareddata/*
!apps/ios/PulseCoffeeApp.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/
apps/ios/PulseCoffeeApp.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/*
!apps/ios/PulseCoffeeApp.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/Package.resolved

# Xcode build artifacts and user-specific state
**/build/
**/DerivedData/
**/.build/
**/*.xcuserstate
**/xcuserdata/
**/*.xcuserdatad/
**/*.xcworkspace/xcuserdata/

# Swift Package Manager — user-specific state. Package.resolved IS
# committed for reproducible app builds (it's the dependency lockfile).
.swiftpm/

# Carthage / CocoaPods (not used today, but block accidental commits)
Carthage/
Pods/

# App archive artifacts
**/*.ipa
**/*.dSYM
**/*.dSYM.zip

# fastlane (not used today)
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots
fastlane/test_output
